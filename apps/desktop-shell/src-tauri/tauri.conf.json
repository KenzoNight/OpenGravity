{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenGravity",
  "version": "0.1.0",
  "identifier": "com.antigravity.opengravity",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "OpenGravity",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
