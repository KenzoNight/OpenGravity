{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "rootDir": "src",
    "outDir": ".test-dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/shell-state.ts",
    "src/shell-state.test.ts",
    "src/settings-state.ts",
    "src/settings-state.test.ts",
    "src/native-bridge.ts",
    "src/workspace-state.ts",
    "src/workspace-state.test.ts",
    "src/test-suite.ts"
  ]
}
